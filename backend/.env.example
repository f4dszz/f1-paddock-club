# F1 Paddock Club — backend environment variables
# Copy this file to backend/.env and fill in the values you need.
# .env is gitignored; .env.example is not.

# ─── Provider selector ───────────────────────────────────────────────
# Which LLM provider should the itinerary/tour agents use?
#   openai     (default) — needs OPENAI_API_KEY below
#   anthropic            — needs ANTHROPIC_API_KEY below
LLM_PROVIDER=openai


# ─── OpenAI / OpenAI-compatible ──────────────────────────────────────
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Optional: model name. Defaults to gpt-4o-mini (cheap + good for our use case).
# Other reasonable picks: gpt-4o, gpt-4.1-mini, o4-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: base URL for OpenAI-compatible providers
# (DeepSeek, Moonshot/Kimi, Zhipu GLM, Alibaba Qwen, local vLLM, etc.)
# Leave unset to use the official OpenAI endpoint.
# OPENAI_BASE_URL=https://api.deepseek.com/v1


# ─── Anthropic (only if LLM_PROVIDER=anthropic) ──────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy/v1


# ─── Data tools ──────────────────────────────────────────────────────
# SerpAPI — flights (google_flights engine) + hotels (google_hotels engine)
# + Bing/Baidu search. Free 100 searches/month. https://serpapi.com
# SERPAPI_API_KEY=...

# Firecrawl — scrape F1 official ticket pages behind Cloudflare/JS.
# Free 500 pages/month. https://firecrawl.dev
# FIRECRAWL_API_KEY=...

# Tavily — LLM-optimized web search. Free 1000/month. https://tavily.com
# Falls back to DuckDuckGo (free, no key) if not set.
# TAVILY_API_KEY=...

# ─── China OTA (optional, as fallback for Chinese departure routes) ──
# FLIGGY_APP_KEY=...
# FLIGGY_APP_SECRET=...
# BOCHA_API_KEY=...
